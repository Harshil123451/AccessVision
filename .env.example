# ==============================================================================
# AccessVision Environment Variables Example Template
# ==============================================================================
# Copy this file to '.env' in the root directory before running the application:
# cp .env.example .env (on Unix-like systems)
# copy .env.example .env (on Windows PowerShell/CMD)
#
# Do NOT commit your actual '.env' file containing secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FastAPI Backend Settings
# ------------------------------------------------------------------------------
APP_NAME="AccessVision API"
APP_ENV="development"              # Environment: 'development', 'production', 'testing'
DEBUG=true                         # Enables detailed error traceback overlays
PORT=8000                          # Port the FastAPI backend runs on
HOST="127.0.0.1"                   # Use "0.0.0.0" to expose the server to the local network (LAN)

# ------------------------------------------------------------------------------
# 2. AI Inference Engine Configurations
# ------------------------------------------------------------------------------
# INFERENCE_MODE determines model execution. Available values:
# - "local": Loads and runs PyTorch/Ultralytics models on local CPU/GPU (Default).
# - "mock" : Runs simulated responses, avoiding model loading for fast dev testing.
INFERENCE_MODE="local"

# Local PyTorch/Hugging Face Model paths or Hugging Face model IDs
YOLO_MODEL_PATH="yolov8s.pt"
YOLO_CONFIDENCE_THRESHOLD=0.5
CAPTION_MODEL_PATH="Salesforce/blip-image-captioning-base"
VQA_MODEL_PATH="Salesforce/blip-vqa-base"

# ------------------------------------------------------------------------------
# 3. Performance & Resource Allocations
# ------------------------------------------------------------------------------
MAX_IMAGE_SIZE=640                 # Max dimension to clamp the image backend-side
JPEG_QUALITY=80                    # Quality level for compressed image preprocessing
SEMAPHORE_LIMIT=4                  # Limit concurrent neural network calls (prevents VRAM crash)

# ------------------------------------------------------------------------------
# 4. Security & CORS Configurations
# ------------------------------------------------------------------------------
# Shared api key secret to authenticate the frontend with the FastAPI backend
API_KEY_SECRET="development-secret-key"

# JSON array of origins allowed to make requests.
# Set this to specific domain URLs in production (e.g. ["https://my-app.vercel.app"])
ALLOWED_ORIGINS=["*"]

# ------------------------------------------------------------------------------
# 5. Frontend Environment Configuration (Reference)
# ------------------------------------------------------------------------------
# Next.js 15 uses automatic rewrite proxying configured in next.config.ts.
# Frontend API calls to '/api/:path*' are proxied directly to 'http://127.0.0.1:8000/api/:path*'.
# No additional frontend env variables are required unless changing proxy destination.
# If changing the backend URL, update the proxy destination in next.config.ts.
